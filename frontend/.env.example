# Verdora environment — copy to .env

EXPO_PUBLIC_API_URL=https://api.verdora.mock
# Set to false only when EXPO_PUBLIC_API_URL points to a live REST backend.
# Supabase cloud sync works independently of this flag.
EXPO_PUBLIC_USE_MOCK_API=true

# OpenWeather (optional — live weather)
EXPO_PUBLIC_OPENWEATHER_API_KEY=

# Gemini (optional — live chat)
EXPO_PUBLIC_GEMINI_API_KEY=

# Supabase — REQUIRED for cloud data collection (run backend/supabase/schema.sql first)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Expo offline mode if fetch fails during start
# EXPO_OFFLINE=1
